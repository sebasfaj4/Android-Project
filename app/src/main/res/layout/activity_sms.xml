<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textSmsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS Notifications"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSmsInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Enable SMS notifications to receive alerts when inventory is low."
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textPermissionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Permission status: Not granted"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonRequestPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Request SMS Permission" />

        <Button
            android:id="@+id/buttonSendTestNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Send Low Inventory Alert" />

        <TextView
            android:id="@+id/textGrantedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="If permission is granted, the app can send low inventory notifications."
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textDeniedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="If permission is denied, the app will still work, but SMS notifications will stay off."
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>